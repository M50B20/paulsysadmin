---
import { projects, homelabHardware } from '../data/projects';

const featured = projects.find(p => p.featured)!;
const rest      = projects.filter(p => !p.featured);
---

<section id="projects" class="py-28">
  <div class="section-container">

    <div class="reveal mb-14">
      <p class="section-label">// lab & projets</p>
      <h2 class="section-title">Home-Lab & Projets</h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Un environnement de test permanent qui reproduit une infra d'entreprise — pour apprendre en conditions réelles.
      </p>
    </div>

    <!-- ── Featured: Home-Lab ── -->
    <div class="reveal reveal-delay-1 glow-card rounded-2xl bg-bg-card p-7 lg:p-10 mb-8">
      <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-sm font-mono px-2.5 py-0.5 rounded-full bg-violet-500/15 text-violet-300 border border-violet-500/25">Featured</span>
            <span class="text-sm font-mono px-2.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">Actif</span>
          </div>
          <h3 class="text-2xl font-bold text-slate-100">{featured.title}</h3>
          <p class="text-base text-slate-400 mt-1">{featured.subtitle}</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 items-start">

        <!-- Description + hardware -->
        <div class="space-y-7">
          <p class="text-slate-300 leading-relaxed text-base">{featured.description}</p>

          <!-- Hardware cards -->
          <div class="space-y-3">
            <p class="text-sm font-mono text-slate-500 uppercase tracking-widest">Matériel</p>
            {homelabHardware.map(hw => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-bg-elevated border border-violet-500/10">
                <div class="p-2 rounded-lg bg-violet-500/10 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.923a3.375 3.375 0 0 0-3.285 2.602l-2.268 9.64a4.5 4.5 0 0 0-.12 1.03v.228m19.5 0a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3m19.5 0a3 3 0 0 0-3-3H5.25a3 3 0 0 0-3 3" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-base text-slate-200">{hw.name} <span class="font-normal text-slate-500">— {hw.role}</span></div>
                  <div class="text-sm text-slate-400 mt-0.5">{hw.specs.join(' · ')}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- Tech tags -->
          <div class="flex flex-wrap gap-2">
            {featured.tech.map(t => (
              <span class="px-3 py-1.5 rounded-lg text-sm font-medium bg-violet-500/10 text-violet-300 border border-violet-500/20">
                {t.name}
              </span>
            ))}
          </div>
        </div>

        <!-- Network diagram SVG -->
        <div class="rounded-xl bg-bg-elevated border border-violet-500/15 p-5 overflow-x-auto">
          <p class="text-sm font-mono text-slate-500 mb-4 uppercase tracking-widest">Schéma d'architecture</p>
          <svg
            viewBox="0 0 460 340"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-md mx-auto"
            aria-label="Schéma du home-lab"
          >
            <line x1="230" y1="52"  x2="230" y2="78"  stroke="#7c3aed" stroke-width="1.5" stroke-dasharray="4,3" opacity=".5"/>
            <line x1="230" y1="108" x2="230" y2="134" stroke="#7c3aed" stroke-width="1.5" stroke-dasharray="4,3" opacity=".5"/>
            <line x1="230" y1="162" x2="90"  y2="192" stroke="#6366f1" stroke-width="1.5" opacity=".45"/>
            <line x1="230" y1="162" x2="230" y2="192" stroke="#6366f1" stroke-width="1.5" opacity=".45"/>
            <line x1="230" y1="162" x2="370" y2="192" stroke="#6366f1" stroke-width="1.5" opacity=".45"/>
            <line x1="90"  y1="242" x2="90"  y2="268" stroke="#22d3ee" stroke-width="1" opacity=".35"/>

            <rect x="170" y="6"   width="120" height="46" rx="8" fill="#1a1a2e" stroke="#7c3aed" stroke-width="1" opacity=".8"/>
            <text x="230" y="26"  text-anchor="middle" fill="#a78bfa" font-size="9" font-family="monospace" font-weight="600">INTERNET</text>
            <text x="230" y="40"  text-anchor="middle" fill="#64748b" font-size="8" font-family="monospace">ISP / FAI</text>

            <rect x="180" y="78"  width="100" height="30" rx="6" fill="#13132a" stroke="#6366f1" stroke-width="1" opacity=".8"/>
            <text x="230" y="97"  text-anchor="middle" fill="#818cf8" font-size="8" font-family="monospace">Routeur FAI</text>

            <rect x="175" y="134" width="110" height="28" rx="6" fill="#13132a" stroke="#6366f1" stroke-width="1" opacity=".8"/>
            <text x="230" y="152" text-anchor="middle" fill="#818cf8" font-size="8" font-family="monospace">Switch réseau</text>

            <rect x="20" y="192"  width="140" height="50" rx="8" fill="#13132a" stroke="#7c3aed" stroke-width="1.5"/>
            <text x="90" y="212"  text-anchor="middle" fill="#c4b5fd" font-size="8.5" font-family="monospace" font-weight="700">Dell R610</text>
            <text x="90" y="226"  text-anchor="middle" fill="#6366f1"  font-size="7.5" font-family="monospace">Proxmox VE</text>
            <text x="90" y="236"  text-anchor="middle" fill="#475569"  font-size="7"   font-family="monospace">2× Xeon E5645 · 64 Go</text>

            <rect x="172" y="192" width="116" height="50" rx="8" fill="#13132a" stroke="#22d3ee" stroke-width="1"/>
            <text x="230" y="212" text-anchor="middle" fill="#67e8f9" font-size="8.5" font-family="monospace" font-weight="700">HP Victus 15</text>
            <text x="230" y="226" text-anchor="middle" fill="#22d3ee"  font-size="7.5" font-family="monospace">Workstation</text>
            <text x="230" y="236" text-anchor="middle" fill="#475569"  font-size="7"   font-family="monospace">R5 5600H · 40 Go</text>

            <rect x="300" y="192" width="140" height="50" rx="8" fill="#13132a" stroke="#4f46e5" stroke-width="1"/>
            <text x="370" y="212" text-anchor="middle" fill="#a5b4fc" font-size="8.5" font-family="monospace" font-weight="700">Asus F540LJ</text>
            <text x="370" y="226" text-anchor="middle" fill="#6366f1"  font-size="7.5" font-family="monospace">Proxmox 24/7</text>
            <text x="370" y="236" text-anchor="middle" fill="#475569"  font-size="7"   font-family="monospace">Allumé en permanence</text>

            <rect x="18"  y="268" width="144" height="64" rx="8" fill="#0d0d20" stroke="#22d3ee" stroke-width="1" stroke-dasharray="5,3" opacity=".7"/>
            <text x="90" y="284"  text-anchor="middle" fill="#67e8f9" font-size="7.5" font-family="monospace" font-weight="700">VMs Proxmox</text>
            <text x="90" y="297"  text-anchor="middle" fill="#94a3b8" font-size="7"   font-family="monospace">● Wazuh SIEM</text>
            <text x="90" y="309"  text-anchor="middle" fill="#94a3b8" font-size="7"   font-family="monospace">● Windows Server / AD</text>
            <text x="90" y="321"  text-anchor="middle" fill="#94a3b8" font-size="7"   font-family="monospace">● PKI / Divers services</text>
          </svg>
        </div>
      </div>
    </div>

    <!-- ── Other projects ── -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {rest.map((project, i) => (
        <div class={`reveal reveal-delay-${(i % 4) + 1} glow-card rounded-2xl bg-bg-card p-6 flex flex-col gap-4`}>
          <div class="flex items-center justify-between">
            {project.status === 'active'
              ? <span class="text-sm font-mono px-2.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-500/25">Actif</span>
              : <span class="text-sm font-mono px-2.5 py-0.5 rounded-full bg-slate-700/60 text-slate-400 border border-slate-600/40">À venir</span>
            }
          </div>

          <div>
            <h3 class="font-semibold text-slate-100 text-base">{project.title}</h3>
            <p class="text-sm text-slate-500 mt-0.5">{project.subtitle}</p>
          </div>

          <p class="text-sm text-slate-400 leading-relaxed flex-1">{project.description}</p>

          <div class="flex flex-wrap gap-1.5">
            {project.tech.map(t => (
              <span class="px-2.5 py-1 rounded text-sm bg-slate-800/60 border border-slate-700/40 text-slate-400 font-mono">
                {t.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
