---
import { skillCategories } from '../data/skills';

const icons: Record<string, string> = {
  infra:    `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.923a3.375 3.375 0 0 0-3.285 2.602l-2.268 9.64a4.5 4.5 0 0 0-.12 1.03v.228m19.5 0a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3m19.5 0a3 3 0 0 0-3-3H5.25a3 3 0 0 0-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z"/></svg>`,
  network:  `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
  security: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  dev:      `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"/></svg>`,
};
---

<section id="skills" class="py-28 bg-grid">
  <div class="section-container">

    <div class="reveal mb-14 text-center">
      <p class="section-label">// expertise</p>
      <h2 class="section-title">Compétences</h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Du bare-metal au SIEM, en passant par les scripts d'automatisation.
      </p>
    </div>

    <!-- 2 cols on md, 4 on xl -->
    <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-6">
      {skillCategories.map((cat, i) => (
        <div
          class={`reveal reveal-delay-${(i % 4) + 1} glow-card rounded-2xl bg-bg-card p-7 flex flex-col gap-6`}
        >
          <!-- Header -->
          <div class="flex items-start gap-4">
            <div class={`p-3 rounded-xl border ${cat.accentClass} shrink-0`} set:html={icons[cat.id]} />
            <div>
              <h3 class="font-semibold text-slate-100 text-base leading-snug">{cat.title}</h3>
              <p class="text-sm text-slate-500 mt-1">{cat.description}</p>
            </div>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {cat.skills.map(skill => (
              <span class={`px-3 py-1.5 rounded-lg text-sm font-medium border ${cat.accentClass} transition-colors hover:brightness-125`}>
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
