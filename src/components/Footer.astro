---
const year = new Date().getFullYear();

const links = [
  { href: '#about',          label: 'À propos' },
  { href: '#skills',         label: 'Compétences' },
  { href: '#projects',       label: 'Projets' },
  { href: '#timeline',       label: 'Parcours' },
  { href: '#certifications', label: 'Certifications' },
  { href: '#contact',        label: 'Contact' },
];
---

<footer class="border-t border-violet-500/10 bg-bg-base dark:bg-bg-base py-10">
  <div class="section-container flex flex-col sm:flex-row items-center justify-between gap-6">

    <!-- Logo + copyright -->
    <div class="flex flex-col items-center sm:items-start gap-1">
      <a href="#hero" class="font-mono text-sm font-semibold gradient-text-violet">Paul P.</a>
      <p class="text-xs text-slate-600">&copy; {year} · Ariège</p>
    </div>

    <!-- Nav links -->
    <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2">
      {links.map(link => (
        <a href={link.href} class="text-xs text-slate-500 hover:text-violet-300 transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Built with -->
    <p class="text-xs text-slate-600 text-center sm:text-right">
      Fait avec
      <span class="text-violet-500/70">Astro</span> &amp;
      <span class="text-cyan-500/70">Tailwind</span>
    </p>
  </div>
</footer>
