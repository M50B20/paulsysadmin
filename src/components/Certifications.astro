---
import { certGroups, upcomingCerts } from '../data/certifications';
---

<section id="certifications" class="py-28">
  <div class="section-container">

    <div class="reveal mb-14">
      <p class="section-label">// certifications</p>
      <h2 class="section-title">Certifications obtenues</h2>
    </div>

    <div class="space-y-12">
      {certGroups.map((group, gi) => (
        <div class={`reveal reveal-delay-${(gi % 4) + 1}`}>

          <!-- Issuer header -->
          <div class="flex items-center gap-3 mb-5">
            <div class="h-6 w-1 rounded-full" style={`background-color: ${group.color}`} />
            <h3 class="font-semibold text-slate-200 text-lg">
              {group.shortName ?? group.issuer}
            </h3>
          </div>

          <!-- Cert list -->
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            {group.certs.map(cert => (
              <div class="glow-card rounded-xl bg-bg-card p-5 flex flex-col gap-2">
                <p class="text-base text-slate-200 leading-snug">{cert.name}</p>
                <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-500">
                  <span>{cert.date}</span>
                  {cert.expires && (
                    <span class="text-slate-600">expire {cert.expires}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Upcoming -->
    <div class="reveal mt-14 pt-10 border-t border-violet-500/10">
      <p class="text-sm font-mono text-slate-500 uppercase tracking-widest mb-5">Prochaines certifications visées</p>
      <div class="flex flex-wrap gap-3">
        {upcomingCerts.map(cert => (
          <div class="flex items-center gap-2 px-5 py-2.5 rounded-xl border border-dashed border-slate-700/50 text-base text-slate-500 hover:border-violet-500/40 hover:text-slate-300 transition-colors cursor-default">
            <span class="text-slate-600">+</span>
            {cert.name}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
