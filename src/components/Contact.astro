---
const email    = 'paul.pichon.ciel@gmail.com';
const github   = 'https://github.com/M50B20';
const linkedin = 'https://www.linkedin.com/in/paul-p28535/';
---

<section id="contact" class="py-28">
  <div class="section-container">

    <div class="reveal mb-16 text-center">
      <p class="section-label">// restons en contact</p>
      <h2 class="section-title text-center">Contact</h2>
      <p class="text-slate-400 text-lg max-w-lg mx-auto">
        Question sur mes projets, opportunité ou simple prise de contact — n'hésitez pas.
      </p>
    </div>

    <div class="max-w-3xl mx-auto flex flex-col gap-6">

      <!-- Email card -->
      <div class="reveal reveal-delay-1 glow-card rounded-2xl bg-bg-card p-10 text-center">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-600/25 to-indigo-600/25 border border-violet-500/20 flex items-center justify-center mx-auto mb-6">
          <span class="font-mono text-3xl font-black gradient-text">PP</span>
        </div>
        <h3 class="text-xl font-bold text-slate-100 mb-1">Paul P.</h3>
        <p class="text-base text-slate-400 mb-7">Infrastructure & Cybersecurity · Ariège</p>
        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold text-base shadow-glow-violet hover:brightness-110 transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
          </svg>
          {email}
        </a>
      </div>

      <!-- Social links -->
      <div class="reveal reveal-delay-2 grid grid-cols-2 gap-4">

        <a href={github} target="_blank" rel="noopener noreferrer"
           class="glow-card rounded-xl bg-bg-card p-6 flex items-center gap-5 group">
          <div class="w-12 h-12 rounded-lg bg-slate-800/60 border border-slate-700/50 flex items-center justify-center shrink-0 group-hover:border-violet-500/40 transition-colors">
            <svg class="w-6 h-6 text-slate-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </div>
          <div>
            <p class="text-base font-semibold text-slate-200">GitHub</p>
            <p class="text-sm text-slate-500">M50B20</p>
          </div>
        </a>

        <a href={linkedin} target="_blank" rel="noopener noreferrer"
           class="glow-card rounded-xl bg-bg-card p-6 flex items-center gap-5 group">
          <div class="w-12 h-12 rounded-lg bg-[#0077B5]/15 border border-[#0077B5]/30 flex items-center justify-center shrink-0 group-hover:border-[#0077B5]/60 transition-colors">
            <svg class="w-6 h-6 text-[#0077B5]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <p class="text-base font-semibold text-slate-200">LinkedIn</p>
            <p class="text-sm text-slate-500">paul-p28535</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
