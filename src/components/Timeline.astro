---
import { timelineEvents } from '../data/timeline';
import type { TimelineEvent } from '../data/timeline';

const statusClasses: Record<TimelineEvent['status'], string> = {
  completed:    'bg-emerald-500/15 text-emerald-300 border-emerald-500/30',
  'in-progress':'bg-violet-500/15  text-violet-300  border-violet-500/30',
  upcoming:     'bg-slate-700/50   text-slate-400   border-slate-600/40',
};
const statusLabel: Record<TimelineEvent['status'], string> = {
  completed:    'Terminé',
  'in-progress':'En cours',
  upcoming:     'À venir',
};
const typeColor: Record<TimelineEvent['type'], string> = {
  academic: 'border-violet-500 bg-violet-500',
  pro:      'border-cyan-500   bg-cyan-500',
};
const typeLabel: Record<TimelineEvent['type'], string> = {
  academic: 'Formation',
  pro:      'Expérience pro',
};
---

<section id="timeline" class="py-28 bg-grid">
  <div class="section-container">

    <div class="reveal mb-14">
      <p class="section-label">// mon parcours</p>
      <h2 class="section-title">Parcours</h2>
      <div class="flex flex-wrap items-center gap-5 mt-4">
        <div class="flex items-center gap-2 text-base text-slate-400">
          <span class="w-3 h-3 rounded-full bg-violet-500 inline-block"></span> Formation
        </div>
        <div class="flex items-center gap-2 text-base text-slate-400">
          <span class="w-3 h-3 rounded-full bg-cyan-500 inline-block"></span> Expérience pro
        </div>
      </div>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-violet-500/50 via-indigo-500/30 to-transparent" />

      <div class="space-y-10">
        {timelineEvents.map((event, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div class={`reveal reveal-delay-${(i % 4) + 1} relative flex items-start gap-0 sm:gap-8 ${isLeft ? 'sm:flex-row' : 'sm:flex-row-reverse'}`}>

              <!-- Card -->
              <div class={`ml-12 sm:ml-0 glow-card rounded-2xl bg-bg-card p-6 flex-1 ${isLeft ? 'sm:text-right' : ''}`}>
                <div class={`flex flex-wrap gap-2 mb-3 ${isLeft ? 'sm:justify-end' : ''}`}>
                  <span class="text-sm font-mono px-2.5 py-0.5 rounded-full bg-transparent border text-slate-400 border-slate-600/50">
                    {typeLabel[event.type]}
                  </span>
                  <span class={`text-sm font-mono px-2.5 py-0.5 rounded-full border ${statusClasses[event.status]}`}>
                    {statusLabel[event.status]}
                  </span>
                </div>

                <div class="text-sm font-mono text-slate-500 mb-1">{event.period ?? event.year}</div>
                <h3 class="font-bold text-slate-100 text-base sm:text-lg">{event.title}</h3>
                <p class="text-base text-violet-400 font-medium">{event.org}</p>
                {event.location && (
                  <p class="text-sm text-slate-500 flex items-center gap-1 mt-1 sm:justify-start">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                    </svg>
                    {event.location}
                  </p>
                )}
                {event.description && (
                  <p class="text-sm text-slate-400 mt-2 leading-relaxed">{event.description}</p>
                )}
              </div>

              <!-- Dot -->
              <div class="absolute left-4 sm:left-1/2 top-5 sm:-translate-x-1/2 z-10">
                <div class={`w-4 h-4 rounded-full border-2 shadow-sm ${typeColor[event.type]}`} />
              </div>

              <div class="hidden sm:block flex-1" />
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
