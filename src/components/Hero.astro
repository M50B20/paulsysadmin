---
const role = 'Infrastructure & Cybersecurity';
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center bg-hero overflow-hidden pt-16"
>
  <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full bg-violet-600/7 blur-[150px]" />
  <div class="pointer-events-none absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full bg-cyan-500/5 blur-[120px]" />

  <div class="relative z-10 section-container">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-24 items-center">

      <!-- Left: text -->
      <div class="flex flex-col gap-7">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-violet-500/25 bg-violet-500/8 text-violet-300 text-base font-mono self-start animate-fade-in" style="animation-delay:0.1s;opacity:0;animation-fill-mode:forwards">
          <span class="w-2 h-2 rounded-full bg-violet-400 shrink-0"></span>
          BTS CIEL · 2026 · Ariège
        </div>

        <!-- Name -->
        <h1 class="text-6xl sm:text-7xl xl:text-8xl font-black tracking-tight leading-none animate-fade-up" style="animation-delay:0.2s;opacity:0;animation-fill-mode:forwards">
          <span class="gradient-text">Paul P.</span>
        </h1>

        <!-- Role -->
        <p class="text-2xl sm:text-3xl font-semibold text-slate-300 font-mono animate-fade-up" style="animation-delay:0.35s;opacity:0;animation-fill-mode:forwards">
          {role}<span class="text-violet-400 animate-blink">_</span>
        </p>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl text-slate-400 leading-relaxed max-w-lg animate-fade-up" style="animation-delay:0.5s;opacity:0;animation-fill-mode:forwards">
          Titulaire du BTS CIEL, je poursuis avec un Bachelor ASR puis le Mastère MICSI (CESI) en alternance.
          Passionné par l'infra, les réseaux et la cybersécurité.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 animate-fade-up" style="animation-delay:0.65s;opacity:0;animation-fill-mode:forwards">
          <a
            href="/projets"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold text-base shadow-glow-violet hover:brightness-110 transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.923a3.375 3.375 0 0 0-3.285 2.602l-2.268 9.64a4.5 4.5 0 0 0-.12 1.03v.228m19.5 0a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3m19.5 0a3 3 0 0 0-3-3H5.25a3 3 0 0 0-3 3" />
            </svg>
            Voir les projets
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-violet-500/30 text-violet-300 font-semibold text-base hover:bg-violet-500/10 hover:border-violet-500/60 transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            Contact
          </a>
        </div>

        <!-- Page shortcuts -->
        <div class="flex flex-wrap gap-2 animate-fade-up" style="animation-delay:0.8s;opacity:0;animation-fill-mode:forwards">
          {[
            { href: '/competences', label: 'Compétences' },
            { href: '/parcours',    label: 'Parcours' },
          ].map(({ href, label }) => (
            <a href={href} class="px-3 py-1 rounded-full bg-slate-800/50 border border-slate-700/50 text-slate-400 text-sm font-mono hover:text-violet-300 hover:border-violet-500/40 transition-colors">
              {label} →
            </a>
          ))}
        </div>
      </div>

      <!-- Right: terminal card -->
      <div class="hidden lg:block animate-fade-up" style="animation-delay:0.4s;opacity:0;animation-fill-mode:forwards">
        <div class="glow-card rounded-2xl bg-bg-card overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3.5 bg-bg-elevated border-b border-violet-500/10">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-3 text-sm font-mono text-slate-500">paul@lab ~ bash</span>
          </div>
          <div class="p-7 font-mono text-base space-y-4 text-slate-300">
            <div>
              <span class="text-violet-400">~ $</span> <span class="text-slate-200">whoami</span>
            </div>
            <div class="pl-5 text-cyan-400">paul.p — en Ariège</div>

            <div>
              <span class="text-violet-400">~ $</span> <span class="text-slate-200">cat parcours.txt</span>
            </div>
            <div class="pl-5 text-slate-300 leading-relaxed text-sm">
              BTS CIEL — Lycée de Mirepoix (2024–2026) ✓<br/>
              CDD Alsatis Services — juil.–sept. 2026<br/>
              Bachelor ASR → Mastère MICSI (CESI) ↗
            </div>

            <div>
              <span class="text-violet-400">~ $</span> <span class="text-slate-200">ls homelab/</span>
            </div>
            <div class="pl-5 text-emerald-400">
              proxmox/&nbsp;&nbsp;wazuh/&nbsp;&nbsp;ad-pki/&nbsp;&nbsp;fortigate/
            </div>

            <div>
              <span class="text-violet-400">~ $</span> <span class="text-slate-200">ls certs/ | wc -l</span>
            </div>
            <div class="pl-5 text-slate-400">18+ certifications (FCA, FCF, PCEP…)</div>

            <div class="flex items-center gap-0 mt-2">
              <span class="text-violet-400">~ $</span>
              <span class="ml-2 w-2 h-5 bg-violet-400 animate-blink inline-block" />
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-600 animate-fade-in" style="animation-delay:1.2s;opacity:0;animation-fill-mode:forwards">
    <span class="text-sm font-mono tracking-widest uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-violet-500/60 to-transparent animate-float"></div>
  </div>
</section>
